# Airtable — get from airtable.com/account (Personal Access Token)
AIRTABLE_API_KEY=pat_xxxxx

# Airtable — get from your base URL: airtable.com/appXXXXX
AIRTABLE_BASE_ID=appXXXXX

# Table IDs — get from Airtable after creating tables (right-click table → API docs)
AIRTABLE_ORDERS_TABLE=tblXXXXX
AIRTABLE_ORDER_LINES_TABLE=tblXXXXX
AIRTABLE_CUSTOMERS_TABLE=tblXXXXX
AIRTABLE_STOCK_TABLE=tblXXXXX
AIRTABLE_DELIVERIES_TABLE=tblXXXXX
AIRTABLE_STOCK_PURCHASES_TABLE=tblXXXXX
AIRTABLE_STOCK_ORDERS_TABLE=tblXXXXX
AIRTABLE_STOCK_ORDER_LINES_TABLE=tblXXXXX

# Premade Bouquets (required for premade bouquet feature)
AIRTABLE_PREMADE_BOUQUETS_TABLE=tblXXXXX
AIRTABLE_PREMADE_BOUQUET_LINES_TABLE=tblXXXXX

# Optional tables (features degrade gracefully if not set)
AIRTABLE_LEGACY_ORDERS_TABLE=tblXXXXX
AIRTABLE_WEBHOOK_LOG_TABLE=tblXXXXX
AIRTABLE_MARKETING_SPEND_TABLE=tblXXXXX
AIRTABLE_STOCK_LOSS_LOG_TABLE=tblXXXXX
AIRTABLE_PRODUCT_CONFIG_TABLE=tblXXXXX
AIRTABLE_SYNC_LOG_TABLE=tblXXXXX
AIRTABLE_APP_CONFIG_TABLE=tblXXXXX
AIRTABLE_FLORIST_HOURS_TABLE=tblXXXXX

# Claude API for auto-translation (haiku-4-5 model)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Wix webhook signature verification
# Get from Wix Automations → your webhook action → Show secret
WIX_WEBHOOK_SECRET=xxxxx

# Role PINs — change before production!
PIN_OWNER=1234
PIN_FLORIST=5678
PIN_DRIVER_TIMUR=9012
PIN_DRIVER_NIKITA=3456
PIN_DRIVER_DMITRI=7890

# Server
PORT=3001
NODE_ENV=development

# --- PRODUCTION ONLY (set in Railway dashboard) ---

# CORS: comma-separated list of allowed frontend origins
# Set to your actual Vercel URLs after deployment
# Example: https://blossom-florist.vercel.app,https://blossom-delivery.vercel.app,https://blossom-dashboard.vercel.app
CORS_ORIGINS=
