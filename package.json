{
  "name": "flower-studio",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "backend",
    "apps/florist",
    "apps/delivery",
    "apps/dashboard"
  ],
  "scripts": {
    "backend": "npm run dev --workspace=backend",
    "florist": "npm run dev --workspace=apps/florist",
    "delivery": "npm run dev --workspace=apps/delivery",
    "dashboard": "npm run dev --workspace=apps/dashboard",
    "harness": "HARNESS_MOCK_WIX=1 node backend/scripts/start-test-backend.js",
    "test:e2e": "node scripts/e2e-test.js",
    "test:e2e:ui": "playwright test",
    "lab:db:up": "docker compose -f docker-compose.lab.yml up -d postgres && docker compose -f docker-compose.lab.yml exec -T postgres sh -c 'until pg_isready -U lab -d lab; do sleep 0.5; done'",
    "lab:db:down": "docker compose -f docker-compose.lab.yml down",
    "lab:db:logs": "docker compose -f docker-compose.lab.yml logs -f postgres",
    "lab:migrate": "DATABASE_URL=postgres://lab:lab@localhost:5433/lab node backend/src/db/migrate.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
